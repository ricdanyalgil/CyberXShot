{
  "name": "cyberxshot",
  "version": "0.1.8",
  "description": "Captura de tela rápida, privada e multiplataforma para macOS e Windows.",
  "main": "dist-electron/main.cjs",
  "author": "CyberXShot contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricdanyalgil/CyberXShot.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "concurrently": "9.2.4",
    "cross-env": "10.1.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wait-on": "9.1.0"
  },
  "build": {
    "appId": "com.cyberxshot.app",
    "productName": "CyberXShot",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ricdanyalgil",
        "repo": "CyberXShot"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": "-",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "CyberXShot-${version}-${arch}.${ext}",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "CyberXShot precisa acessar a tela para criar capturas selecionadas."
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "CyberXShot-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "CyberXShot-Portable-${version}-${arch}.${ext}"
    }
  }
}
